{
  "name": "quaid-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "serve": "QUAID_PLAYGROUND_AUTO_ENABLE_EXTRACTION=1 QUAID_BIN=../target/release/quaid QUAID_DB=\"$PWD/.data/memory.db\" vite",
    "build": "tsc -b && vite build",
