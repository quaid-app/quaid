#!/usr/bin/env sh
# Wrapper shipped with the quaid npm package.
# postinstall.js downloads the native binary as quaid.bin alongside this script.
# If the binary wasn't downloaded (unsupported platform, network failure, CI skip),
# print guidance instead of failing silently.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NATIVE_BIN="${SCRIPT_DIR}/quaid.bin"

if [ -x "$NATIVE_BIN" ]; then
  exec "$NATIVE_BIN" "$@"
fi

echo "quaid: native binary not found at ${NATIVE_BIN}" >&2
echo "" >&2
echo "The postinstall download may have been skipped (unsupported platform, network" >&2
echo "failure, or CI environment). Install manually:" >&2
echo "" >&2
echo "  curl -fsSL https://raw.githubusercontent.com/quaid-app/quaid/main/scripts/install.sh | sh" >&2
echo "" >&2
echo "npm installs the online channel only. For an offline-safe build, download an" >&2
echo "airgapped asset from: https://github.com/quaid-app/quaid/releases" >&2
exit 1
