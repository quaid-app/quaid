---
interface Props {
	title: string;
	primaryHref: string;
	primaryText: string;
	secondaryHref?: string;
	secondaryText?: string;
}

const { title, primaryHref, primaryText, secondaryHref, secondaryText } = Astro.props;
---

<section class="gb-guide-action">
	<div class="gb-guide-action__copy">
		<h3>{title}</h3>
		<div class="gb-guide-action__body">
			<slot />
		</div>
	</div>
	<div class="gb-guide-action__links">
		<a class="gb-guide-action__link is-primary" href={primaryHref}>{primaryText}</a>
		{
			secondaryHref &&
			secondaryText && <a class="gb-guide-action__link" href={secondaryHref}>{secondaryText}</a>
		}
	</div>
</section>

<style>
	.gb-guide-action {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.25rem 2rem;
		padding: clamp(1.35rem, 3vw, 2.25rem);
		border-radius: 1.25rem;
		border: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 72%, transparent);
		background: linear-gradient(145deg, rgba(255, 255, 255, 0.045), rgba(240, 143, 110, 0.085));
		box-shadow: 0 20px 34px -30px rgba(30, 20, 15, 0.45);
	}

	.gb-guide-action__copy {
		display: grid;
		gap: 0.65rem;
		max-width: 40rem;
	}

	.gb-guide-action h3 {
		margin: 0;
		color: var(--gb-on-surface);
		font-size: clamp(1.35rem, 2vw, 1.85rem);
		font-weight: 760;
		letter-spacing: -0.03em;
	}

	.gb-guide-action__body {
		color: var(--sl-color-gray-3);
		line-height: 1.65;
	}

	.gb-guide-action__body :global(p) {
		margin: 0;
	}

	.gb-guide-action__links {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.75rem;
	}

	.gb-guide-action__link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 9.75rem;
		padding: 0.8rem 1.15rem;
		border-radius: 0.75rem;
		border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 55%, transparent);
		color: var(--gb-on-surface);
		font-weight: 700;
		text-decoration: none;
		background: rgba(255, 255, 255, 0.02);
	}

	.gb-guide-action__link.is-primary {
		border-color: rgba(240, 143, 110, 0.38);
		background: linear-gradient(135deg, rgba(240, 143, 110, 0.92), rgba(184, 82, 46, 0.92));
		color: white;
	}

	@media (max-width: 50rem) {
		.gb-guide-action {
			flex-direction: column;
			align-items: stretch;
		}

		.gb-guide-action__links {
			justify-content: stretch;
		}

		.gb-guide-action__link {
			flex: 1 1 100%;
		}
	}
</style>
